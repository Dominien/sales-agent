# sales-agent — environment variables
#
# Most credentials are handled by your harness via MCP OAuth flows.
# These env vars are ONLY needed when you want to use the local CLI fallback
# paths (Path B) instead of the MCP paths.
#
# Run `npx tsx src/init.ts` — the wizard will leave only the vars you need
# uncommented for your chosen CRM/channels.

# ─── Gmail (channel: email) — required only if you want CLI fallback ───────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── LinkedIn (channel: linkedin) ─────────────────────────────────────────
# No env vars. The linkedin-mcp-server stores its session under ~/.linkedin-mcp/
# Run `uvx linkedin-scraper-mcp@latest --login` once to authenticate.

# ─── HubSpot (crm: hubspot) — only needed for CLI fallback ─────────────────
HUBSPOT_API_TOKEN=

# ─── Close (crm: close) — only needed for CLI fallback ─────────────────────
CLOSE_API_KEY=

# ─── Attio (crm: attio) — only needed for CLI fallback ─────────────────────
ATTIO_API_KEY=

# ─── Salesforce (crm: salesforce) ──────────────────────────────────────────
# Uses sfdx CLI auth. Run `sf org login web --alias default`.
# No env vars — CLI reads ~/.sfdx config.
